# OpenChat Server Configuration — Phase 4
# ─────────────────────────────────────────────────────────────────────────────

# Port the server listens on (wss://)
PORT=4000

# ── Password / JWT ────────────────────────────────────────────────────────────
# JWT_SECRET must be a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=5853f4922723b4c6d7efa24e40e18718d37053a1c2e8befc47148de1375d88d5041791c394026661d5554d95e28806b2
JWT_EXPIRY=7d

# ── First admin ───────────────────────────────────────────────────────────────
# If set, this username is promoted to admin on registration (even if not first).
# Leave blank to use the "first registered user = admin" rule.
ADMIN_USERNAME=

# ── TLS Certificate ───────────────────────────────────────────────────────────
# Leave blank to use the auto-generated self-signed cert (config/cert.pem).
# Set to absolute paths for your own cert (e.g. Let's Encrypt):
#   CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
#   KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
CERT_PATH=
KEY_PATH=

# ── Limits ────────────────────────────────────────────────────────────────────
# Maximum simultaneous authenticated connections (default: 20)
MAX_CONNECTIONS=20

# Maximum incoming WebSocket message size in bytes (default: 65536 = 64 KB)
MAX_PAYLOAD_BYTES=65536
