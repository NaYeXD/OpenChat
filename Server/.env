# OpenChat Server Configuration — Phase 3
# ─────────────────────────────────────────────────────────────────────────────

# Port the server listens on (wss://)
PORT=4000

# ── Password ──────────────────────────────────────────────────────────────────
# Set this to your chosen password.
# On first run the server will print a bcrypt hash — replace this value with
# that hash to avoid re-hashing on every restart (recommended).
# Example hashed value (DO NOT use this — generate your own):
#   SERVER_PASSWORD=$2b$12$...
SERVER_PASSWORD=helloworld

# ── TLS Certificate ───────────────────────────────────────────────────────────
# Leave blank to use the auto-generated self-signed cert (config/cert.pem).
# Set to absolute paths for your own cert (e.g. Let's Encrypt):
#   CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
#   KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
CERT_PATH=
KEY_PATH=

# ── Limits ────────────────────────────────────────────────────────────────────
# Maximum simultaneous authenticated connections (default: 20)
MAX_CONNECTIONS=20

# Maximum incoming WebSocket message size in bytes (default: 65536 = 64 KB)
MAX_PAYLOAD_BYTES=65536
