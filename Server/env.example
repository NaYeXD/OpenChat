# OpenChat Server Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Port the server listens on (wss://)
PORT=4000

# ── Password / JWT ────────────────────────────────────────────────────────────
# Generate a secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING
JWT_EXPIRY=7d

# ── First admin ───────────────────────────────────────────────────────────────
# Leave blank to use the "first registered user = admin" rule.
ADMIN_USERNAME=

# ── TLS Certificate ───────────────────────────────────────────────────────────
# Leave blank to use the auto-generated self-signed cert.
# Set to absolute paths for your own cert (e.g. Let's Encrypt):
#   CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
#   KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
CERT_PATH=
KEY_PATH=

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_CONNECTIONS=20
MAX_PAYLOAD_BYTES=65536